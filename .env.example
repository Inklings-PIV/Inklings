# Copy to .env.local and fill in values.
# Set SKIP_ENV_VALIDATION=true to bypass validation in transient contexts.

# REQUIRED ------------------------------------------------------------

# Database (Neon Postgres + pgvector). Every page reads from it.
DATABASE_URL=

# OpenAI text-embedding-3-small. Used by ingestion and the /blots vibe search.
OPENAI_API_KEY=

# Claude (Sonnet 4.6). Used by the LLM colour deriver and later by Quill rewrites.
ANTHROPIC_API_KEY=

# OPTIONAL (required once each consumer ships) -----------------------

# Iron-session signing — for #39 anonymous scribe cookie. Min 32 chars.
# SESSION_SECRET=

# Inngest Cloud — used in prod to send events to the deployed pipeline.
# Local dev hits the Inngest dev server instead, so these stay unset.
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=

# PUBLIC -------------------------------------------------------------

NEXT_PUBLIC_APP_URL=http://localhost:3000
