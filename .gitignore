# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# tests
/playwright-report
/test-results
/blob-report
/playwright/.cache

# drizzle
/drizzle/migrations/meta

# pg_catalog cache (refetched weekly by lib/ingestion/gutenberg-catalog.ts)
/.cache

# editor
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
