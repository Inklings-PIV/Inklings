{
  "name": "inklings",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@11.0.9",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:e2e": "playwright test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:ping": "tsx lib/db/ping.ts",
    "db:migrate:prod": "cross-env DRIZZLE_ENV=prod drizzle-kit migrate",
    "seed:tracer:prod": "cross-env DRIZZLE_ENV=prod tsx scripts/seed-tracer.ts",
    "seed:tracer": "tsx scripts/seed-tracer.ts",
    "ingest:book": "tsx scripts/ingest-book.ts",
    "recompute:layout": "tsx scripts/recompute-layout.ts",
    "recompute:layout:prod": "cross-env NODE_ENV=production tsx scripts/recompute-layout.ts",
    "recompute:by-hue": "tsx scripts/recompute-by-hue.ts",
    "recompute:by-hue:prod": "cross-env DRIZZLE_ENV=prod tsx scripts/recompute-by-hue.ts",
    "backfill:embeddings": "tsx scripts/backfill-embeddings.ts",
    "backfill:embeddings:prod": "cross-env DRIZZLE_ENV=prod tsx scripts/backfill-embeddings.ts",
    "seed:corpus": "tsx scripts/seed-corpus.ts",
    "seed:all": "tsx scripts/seed-all.ts",
    "derive:colours": "tsx scripts/derive-colours.ts",
    "derive:colours:prod": "cross-env DRIZZLE_ENV=prod tsx scripts/derive-colours.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ],
    "ignoredBuiltDependencies": [
      "@vaadin/vaadin-usage-statistics",
      "protobufjs"
    ]
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.78",
    "@ai-sdk/openai": "^3.0.64",
    "@neondatabase/serverless": "^1.1.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@tanstack/react-query": "^5.100.11",
    "@tiptap/pm": "^3.23.4",
    "@tiptap/react": "^3.23.4",
    "@tiptap/starter-kit": "^3.23.4",
    "ai": "^6.0.185",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "deck.gl": "^9.3.2",
    "drizzle-orm": "^0.45.2",
    "fast-xml-parser": "^5.8.0",
    "inngest": "^4.4.0",
    "iron-session": "^8.0.4",
    "lucide-react": "^1.16.0",
    "motion": "^12.39.0",
    "next": "16.2.6",
    "next-safe-action": "^8.5.2",
    "radix-ui": "^1.4.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "umap-js": "^1.4.0",
    "wink-eng-lite-web-model": "^1.8.1",
    "wink-nlp": "^2.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
